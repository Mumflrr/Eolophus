# .env.example — environment variables for the pipeline
# Copy to .env and fill in values.
# Load with: source .env  or  python-dotenv

# ── Database ──────────────────────────────────────────────────────────────────
# Path to SQLite database file.
# Default: ~/.pipeline/pipeline.db
# PIPELINE_DB=/path/to/pipeline.db

# ── Model files ───────────────────────────────────────────────────────────────
# Directory containing all GGUF model files.
# Used by llama_flags/*.sh scripts.
# Default: ~/models
MODEL_DIR=$HOME/models

# ── Langfuse observability ────────────────────────────────────────────────────
# URL of self-hosted Langfuse instance (Docker in WSL2).
# Default: http://localhost:3000
LANGFUSE_HOST=http://localhost:3000

# Langfuse credentials (set via Langfuse UI on first run).
# LANGFUSE_PUBLIC_KEY=pk-...
# LANGFUSE_SECRET_KEY=sk-...

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level for pipeline output.
# Options: DEBUG, INFO, WARNING, ERROR
# Default: INFO
LOG_LEVEL=INFO

# ── Runtime overrides ────────────────────────────────────────────────────────
# Set by run.py based on CLI flags — do not set manually unless testing.
# PIPELINE_NO_ENSEMBLE=1    # Skip critique ensemble
# PIPELINE_FORCE_SHORT=1    # Force short mode regardless of classification
